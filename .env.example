# ─────────────────────────────────────────────────────────────────────────────
# Target Application
# ─────────────────────────────────────────────────────────────────────────────
# Base URL used by Playwright's page.goto() and relative navigation
BASE_URL=https://your-app.example.com

# ─────────────────────────────────────────────────────────────────────────────
# System API
# ─────────────────────────────────────────────────────────────────────────────
# Base URL for REST API requests (may differ from BASE_URL in multi-service setups)
API_BASE_URL=https://your-app.example.com/api

# Bearer token or API key passed in the Authorization header
API_KEY=your_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Test User Credentials
# ─────────────────────────────────────────────────────────────────────────────
# The account whose password will be reset during the test
TEST_USER_EMAIL=your-test-account@gmail.com

# The account's password before the reset (used to verify old credentials no longer work)
TEST_USER_CURRENT_PASSWORD=OldPassword123!

# The password the test will set during the reset workflow
TEST_USER_NEW_PASSWORD=NewPassword456!

# ─────────────────────────────────────────────────────────────────────────────
# Gmail API – OAuth 2.0 (for reading the reset email)
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token

# Gmail address associated with the OAuth credentials (must match TEST_USER_EMAIL or be a dedicated inbox)
GMAIL_USER=your-test-account@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# Override / Mock mode (no Gmail credentials needed)
# Set this to skip Gmail entirely and use a manually obtained reset link.
# Useful for local POC runs before Gmail OAuth is configured.
# Leave blank (or remove) when running with real Gmail credentials.
# ─────────────────────────────────────────────────────────────────────────────
RESET_LINK_OVERRIDE=
